# Copy this file to .env.local and fill in your values

# Required for NextAuth (generate a random string)
NEXTAUTH_SECRET=your_random_secret_here_at_least_32_chars
NEXTAUTH_URL=http://localhost:3000

# Optional: Google OAuth (free - create at console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional: Google AdSense publisher ID (earns you money, costs nothing)
NEXT_PUBLIC_ADSENSE_PUBLISHER_ID=ca-pub-XXXXXXXXXXXXXXXX
