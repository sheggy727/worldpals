generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id                   String    @id @default(cuid())
  email                String    @unique
  password             String?
  displayName          String?
  photoPath            String?
  bio                  String?
  age                  Int?
  country              String?
  languages            String    @default("[]")
  interests            String    @default("[]")
  countriesWantConnect String    @default("[]")
  isOnboarded          Boolean   @default(false)
  blockedUsers         String    @default("[]")
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  swipesSent     Swipe[]   @relation("SwipeSender")
  swipesReceived Swipe[]   @relation("SwipeReceiver")
  matchesA       Match[]   @relation("MatchUserA")
  matchesB       Match[]   @relation("MatchUserB")
  messagesSent   Message[]
  reports        Report[]
}

model Swipe {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  direction  String
  createdAt  DateTime @default(now())

  sender   User @relation("SwipeSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("SwipeReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
}

model Match {
  id          String    @id @default(cuid())
  userAId     String
  userBId     String
  createdAt   DateTime  @default(now())
  lastMessage String?
  lastMsgAt   DateTime?

  userA    User      @relation("MatchUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB    User      @relation("MatchUserB", fields: [userBId], references: [id], onDelete: Cascade)
  messages Message[]

  @@unique([userAId, userBId])
}

model Message {
  id        String   @id @default(cuid())
  matchId   String
  senderId  String
  text      String
  createdAt DateTime @default(now())
  read      Boolean  @default(false)

  match  Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  sender User  @relation(fields: [senderId], references: [id], onDelete: Cascade)
}

model Report {
  id          String   @id @default(cuid())
  reporterId  String
  reportedId  String
  reason      String
  description String?
  status      String   @default("pending")
  createdAt   DateTime @default(now())

  reporter User @relation(fields: [reporterId], references: [id], onDelete: Cascade)
}
